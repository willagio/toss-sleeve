# toss-sleeve 통합 스모크·캐던스 프로브용 환경변수. `.env` 로 복사 후 값 채움(.env 는 gitignored).
# tools/cadence_probe.py 와 tests/integration/test_smoke.py 가 이 값을 읽는다(프로브는 .env 자동 로드).
#
# 시크릿은 커밋 금지. 토스 Open API 는 IP 허용목록이 필요하다 — 개발자포털에 이 머신의 egress IP 를
# 등록해야 인증콜이 통과한다.

# OAuth2 client_credentials 자격증명 (필수).
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# 계좌 식별자(accountSeq, X-Tossinvest-Account 헤더). 비우면 GET /api/v1/accounts 첫 계좌 사용.
TOSS_ACCOUNT_SEQ=

# 캐던스 프로브 측정 대상 심볼(콤마구분). 미설정 시 기본 KR 대형주 8종.
TOSS_PROBE_SYMBOLS=005930,000660,035720,051910,006400,035420,028260,068270
